# LLM APIs
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
OLLAMA_HOST=http://localhost:11434
ALLOW_PRIVATE_OLLAMA_HOSTS=false

# Frontend URL (used in email links)
FRONTEND_BASE_URL=http://localhost:5173

# Database
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/cra_db
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800
DB_CONNECT_TIMEOUT_SECONDS=10
ANALYSIS_QUEUE_POLL_INTERVAL_SECONDS=2
ANALYSIS_QUEUE_BATCH_SIZE=3
ANALYSIS_QUEUE_MAX_ATTEMPTS=5
ANALYSIS_QUEUE_BASE_RETRY_SECONDS=15
ANALYSIS_QUEUE_STALE_LOCK_SECONDS=300
ANALYSIS_QUEUE_LOCK_HEARTBEAT_SECONDS=15
WEBHOOK_MAX_BODY_BYTES=5000000

# GitHub App
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----...
GITHUB_CLIENT_ID=Iv1.xxx
GITHUB_CLIENT_SECRET=xxx
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
AUTH_REGISTER_RATE_LIMIT=5/minute
AUTH_LOGIN_RATE_LIMIT=5/minute
AUTH_PASSWORD_RESET_RATE_LIMIT=5/minute
AUTH_EMAIL_VERIFY_RATE_LIMIT=5/minute
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
EMAIL_VERIFICATION_TOKEN_EXPIRE_MINUTES=1440

# Email delivery (optional; if unset, emails are logged)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM=noreply@code-review-agent.local
SMTP_REQUIRED_IN_PRODUCTION=true

# Observability
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2
SENTRY_PROFILES_SAMPLE_RATE=0.0

# Optional Redis for multi-instance websocket fan-out
REDIS_URL=

# Encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FERNET_KEY=your-fernet-key-here

# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
TRUST_PROXY_HEADERS=false

# Frontend build/runtime (create frontend/.env for local Vite overrides)
VITE_API_BASE_URL=/api
VITE_WS_BASE_URL=
